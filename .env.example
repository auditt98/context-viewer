# Context Window Viewer — configuration template.
# Copy this file to `.env` and uncomment the lines you want to set.
# CLI flags (--claude / --codex / --host / --port) always win over these.
#
# Multiple paths are joined with the OS path separator:
#   ':' on macOS / Linux
#   ';' on Windows
# Paths support ~, $HOME, %APPDATA% and other env vars.

# ---- Where are your sessions? ----

# macOS / Linux example:
# CLAUDE_SESSIONS_PATH=~/.claude/projects:~/Library/Application Support/Claude/local-agent-mode-sessions
# CODEX_SESSIONS_PATH=~/.codex/sessions:~/.codex/archived_sessions

# Windows example (use ';' between paths):
# CLAUDE_SESSIONS_PATH=%USERPROFILE%\.claude\projects;%APPDATA%\Claude\local-agent-mode-sessions
# CODEX_SESSIONS_PATH=%USERPROFILE%\.codex\sessions;%USERPROFILE%\.codex\archived_sessions

# ---- Server ----

# HOST=127.0.0.1
# PORT=8765
